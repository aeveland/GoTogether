generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Simple test model to verify DB connection
model HealthCheck {
  id        Int      @id @default(autoincrement())
  message   String   @default("Railway DB is working!")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
